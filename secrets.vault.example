# ==============================================================================
# SECRETS.VAULT TEMPLATE
# ==============================================================================
# This is an example secrets file. Copy this file to 'secrets.vault' and populate
# it with your actual passwords:
#
# cp secrets.vault.example secrets.vault
#
# Then, encrypt it using Ansible Vault to secure the passwords:
#
# ansible-vault encrypt secrets.vault --vault-password-file .vault_pass
# ==============================================================================

# Elasticsearch administrator account password ('elastic' superuser)
vault_elasticsearch_admin_password: "your_elastic_admin_password_here"

# Elasticsearch system account password used by Kibana to log in
vault_elasticsearch_kibana_system_password: "your_kibana_system_password_here"

# PostgreSQL database password for the configured application user (e.g., 'ahmed')
vault_postgresql_database_password: "your_postgresql_user_password_here"
