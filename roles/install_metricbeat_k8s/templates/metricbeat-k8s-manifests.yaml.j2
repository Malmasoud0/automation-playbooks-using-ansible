---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: metricbeat
  namespace: {{ metricbeat_k8s_namespace }}
  labels:
    k8s-app: metricbeat

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: metricbeat
  labels:
    k8s-app: metricbeat
rules:
  - apiGroups: [""]
    resources:
      - nodes
      - namespaces
      - events
      - pods
      - services
      - configmaps
      - nodes/metrics
      - nodes/stats
      - nodes/spec
      - nodes/proxy
    verbs: ["get", "list", "watch"]
  - apiGroups: ["extensions"]
    resources:
      - replicasets
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apps"]
    resources:
      - statefulsets
      - daemonsets
      - deployments
      - replicasets
    verbs: ["get", "list", "watch"]
  - apiGroups: ["batch"]
    resources:
      - cronjobs
      - jobs
    verbs: ["get", "list", "watch"]
  - nonResourceURLs:
      - "/metrics"
    verbs: ["get"]

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: metricbeat
subjects:
  - kind: ServiceAccount
    name: metricbeat
    namespace: {{ metricbeat_k8s_namespace }}
roleRef:
  kind: ClusterRole
  name: metricbeat
  apiGroup: rbac.authorization.k8s.io

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: metricbeat-daemonset-config
  namespace: {{ metricbeat_k8s_namespace }}
  labels:
    k8s-app: metricbeat
data:
  metricbeat.yml: |
    metricbeat.modules:
    - module: kubernetes
      metricsets:
        - container
        - node
        - pod
        - system
        - volume
      period: 10s
      host: ${NODE_NAME}
      hosts: ["https://localhost:10250"]
      bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
      ssl.verification_mode: "none"

    output.elasticsearch:
      hosts: ["{{ metricbeat_k8s_elasticsearch_url }}"]
      username: "{{ metricbeat_k8s_elasticsearch_username }}"
      password: "{{ metricbeat_k8s_elasticsearch_password }}"

---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: metricbeat
  namespace: {{ metricbeat_k8s_namespace }}
  labels:
    k8s-app: metricbeat
spec:
  selector:
    matchLabels:
      k8s-app: metricbeat
  template:
    metadata:
      labels:
        k8s-app: metricbeat
    spec:
      serviceAccountName: metricbeat
      terminationGracePeriodSeconds: 30
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      containers:
        - name: metricbeat
          image: {{ metricbeat_k8s_image }}
          args: [
            "-c", "/etc/metricbeat.yml",
            "-e",
            "--system.hostfs=/hostfs",
          ]
          env:
            - name: NODE_NAME
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
          securityContext:
            runAsUser: 0
          resources:
            limits:
              memory: 200Mi
            requests:
              cpu: 100m
              memory: 100Mi
          volumeMounts:
            - name: config
              mountPath: /etc/metricbeat.yml
              subPath: metricbeat.yml
              readOnly: true
            - name: proc
              mountPath: /hostfs/proc
              readOnly: true
            - name: cgroup
              mountPath: /hostfs/sys/fs/cgroup
              readOnly: true
      volumes:
        - name: config
          configMap:
            name: metricbeat-daemonset-config
        - name: proc
          hostPath:
            path: /proc
        - name: cgroup
          hostPath:
            path: /sys/fs/cgroup

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: metricbeat-deployment-config
  namespace: {{ metricbeat_k8s_namespace }}
  labels:
    k8s-app: metricbeat
data:
  metricbeat.yml: |
    metricbeat.modules:
    - module: kubernetes
      metricsets:
        - state_node
        - state_daemonset
        - state_deployment
        - state_replicaset
        - state_statefulset
        - state_pod
        - state_container
        - state_cronjob
        - state_job
      period: 10s
      hosts: ["kube-state-metrics.kube-system.svc.cluster.local:8080"]

    - module: kubernetes
      metricsets:
        - apiserver
      period: 10s
      hosts: ["https://kubernetes.default.svc:443"]
      bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
      ssl.verification_mode: "none"

    output.elasticsearch:
      hosts: ["{{ metricbeat_k8s_elasticsearch_url }}"]
      username: "{{ metricbeat_k8s_elasticsearch_username }}"
      password: "{{ metricbeat_k8s_elasticsearch_password }}"

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: metricbeat-deployment
  namespace: {{ metricbeat_k8s_namespace }}
  labels:
    k8s-app: metricbeat
spec:
  replicas: 1
  selector:
    matchLabels:
      k8s-app: metricbeat
  template:
    metadata:
      labels:
        k8s-app: metricbeat
    spec:
      serviceAccountName: metricbeat
      containers:
        - name: metricbeat
          image: {{ metricbeat_k8s_image }}
          args: [
            "-c", "/etc/metricbeat.yml",
            "-e",
          ]
          resources:
            limits:
              memory: 200Mi
            requests:
              cpu: 100m
              memory: 100Mi
          volumeMounts:
            - name: config
              mountPath: /etc/metricbeat.yml
              subPath: metricbeat.yml
              readOnly: true
      volumes:
        - name: config
          configMap:
            name: metricbeat-deployment-config
